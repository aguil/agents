{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "types": ["bun"],
    "baseUrl": ".",
    "paths": {
      "@aguil/agents-agentsd": ["packages/agentsd/src/index.ts"],
      "@aguil/agents-context": ["packages/context/src/index.ts"],
      "@aguil/agents-core": ["packages/core/src/index.ts"],
      "@aguil/agents-publish": ["packages/publish/src/index.ts"],
      "@aguil/agents-tracker": ["packages/tracker/src/index.ts"],
      "@aguil/agents-work-queue": ["packages/work-queue/src/index.ts"],
      "@aguil/agents-workers": ["packages/workers/src/index.ts"],
      "@aguil/agents-workflow": ["packages/workflow/src/index.ts"],
      "@aguil/agents-workspace": ["packages/workspace/src/index.ts"],
      "@aguil/agents-code-review": ["harnesses/code-review/src/index.ts"],
      "@aguil/agents-code-review-inbox": [
        "packages/code-review-inbox/src/index.ts"
      ],
      "@aguil/agents-execution": ["packages/execution/src/index.ts"],
      "@aguil/agents-github": ["packages/github/src/index.ts"],
      "@aguil/agents-orchestration": ["packages/orchestration/src/index.ts"],
      "@aguil/agents-pr-feedback": ["packages/pr-feedback/src/index.ts"],
      "@aguil/agents-reporting": ["packages/reporting/src/index.ts"],
      "@aguil/agents-triage": ["packages/triage/src/index.ts"],
      "@aguil/agents-telemetry": ["packages/telemetry/src/index.ts"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "harnesses/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
