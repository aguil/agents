{
  "name": "@aguil/agents",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "harnesses/*"
  ],
  "scripts": {
    "agents": "bun run packages/cli/src/index.ts",
    "build": "bun build packages/cli/src/index.ts --outfile=dist/index.js --target=bun",
    "check": "bun run typecheck && bun run lint",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "preagents": "bun run prepare-prompts",
    "postbuild": "bun run scripts/create-launcher.ts",
    "prepare-npm-publish": "bun run scripts/prepare-npm-publish.ts",
    "publish:npm:pack:test": "bun run publish:npm:verify && bun run build && bun run scripts/prepare-npm-publish.ts -- --version 0.0.0-canary && npm pack ./.npm-publish-pack --pack-destination ./.npm-publish-pack",
    "publish:npm:verify": "bun install --frozen-lockfile && bun run check && bun run test:ci",
    "release:tag": "bun run scripts/release-annotated-tag.ts",
    "prebuild": "bun run prepare-prompts",
    "prepare-prompts": "bun run scripts/embed-prompts.ts",
    "pretest": "bun run prepare-prompts",
    "pretypecheck": "bun run prepare-prompts",
    "test": "bun test",
    "test:coverage": "bun run prepare-prompts && bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "test:ci": "bun run prepare-prompts && bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --reporter=junit --reporter-outfile=coverage/junit.xml",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "1.3.14",
    "typescript": "^6.0.3"
  }
}
